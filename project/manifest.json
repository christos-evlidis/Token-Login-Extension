{
  "manifest_version": 3,
  "name": "Token Login Extension",
  "version": "1.0.0",
  "description": "",
  "permissions": [
    "tabs",
    "storage",
    "windows",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "incognito": "split",
  "action": {
    "default_popup": "src/popup/html/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/discord-inject.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  }
}